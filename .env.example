# ============================================
# Nexara AI - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# LLM API Keys (Optional - enables AI-powered analysis)
# Without these, the system uses rule-based analysis (still fully functional)
# You can configure any combination of these providers.
# ============================================

# OpenAI API Key (uses gpt-4o-mini)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API Key (uses claude-3-5-sonnet)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini API Key (uses gemini-1.5-flash)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Groq API Key (uses llama-3.1-70b-versatile)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=

# Cohere API Key (uses command-r-plus)
# Get yours at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=
